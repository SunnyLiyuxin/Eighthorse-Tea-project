# LLM 接入配置（复制为 .env 后填写真实值；.env 不进 Git）
# 未填 LLM_API_KEY / LLM_BASE_URL 时，后端自动走 mock_outputs 兜底，行为与未接 LLM 时一致。
# 字段经 pydantic-settings 大小写不敏感读取：LLM_API_KEY <-> llm_api_key。

# API key（明文只放在 .env，绝不进被跟踪文件）
LLM_API_KEY=

# 完整 base path（SDK 在其后拼 /chat/completions，不自动加 /v1）。
# 学校 GLM 代理 / 智谱官方 / 通义 / 豆包 / DeepSeek 均为 OpenAI 兼容，填各自完整路径：
#   智谱 GLM:  https://open.bigmodel.cn/api/paas/v4
#   通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
#   豆包:      https://ark.cn-beijing.volces.com/api/v3
#   DeepSeek:  https://api.deepseek.com
# 无尾斜杠。
LLM_BASE_URL=

# 模型名
LLM_MODEL=glm-5.2

# 单请求超时（秒）；防线程池被长调用占满
LLM_TIMEOUT=30

# 代理是否支持 OpenAI response_format={"type":"json_object"}。
# 学校代理若不支持可设 false，后端走防御式解析兜底。
LLM_SUPPORTS_JSON_MODE=true

# ---------------------------------------------------------------------------
# 智谱 CogView 生图配置（与上面的 LLM_* 相互独立）
# ---------------------------------------------------------------------------
# 生图走智谱 CogView-4。与 LLM_* 不共用：当前 LLM_* 多半指向 DeepSeek，
# DeepSeek 不覆盖智谱 /images/generations，故生图必须独立填 IMAGE_* 指向智谱。
# 未填 IMAGE_API_KEY / IMAGE_BASE_URL 时，生图接口走 fallback（不白屏）。
# 字段经 pydantic-settings 大小写不敏感读取：IMAGE_API_KEY <-> image_api_key。

# 智谱平台 API key（与 GLM key 同一把，仅当上面 LLM_API_KEY 已是智谱 key 时可填同值）
IMAGE_API_KEY=

# 智谱官方 base path（SDK 在其后拼 /images/generations）
#   智谱官方: https://open.bigmodel.cn/api/paas/v4
IMAGE_BASE_URL=

# 模型名：cogview-4 / cogview-4-250304 / cogview-3-flash / glm-image
IMAGE_MODEL=cogview-4

# 输出尺寸（CogView-4 支持 1024x1024 / 1440x720 等）
IMAGE_SIZE=1024x1024

# 质量档：hd（精细，约 20s/张）/ standard（快速，约 5-10s/张）
IMAGE_QUALITY=hd

# 单请求超时（秒）；hd 档较慢，默认 90s
IMAGE_TIMEOUT=90

